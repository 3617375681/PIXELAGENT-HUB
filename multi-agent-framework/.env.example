NODE_ENV=development
# Optional: override company-mode records directory (used by tests / alternate data roots)
# RECORDS_ROOT_OVERRIDE=
RECORDS_API_PORT=3100
RECORDS_API_KEY=replace-with-strong-api-key
ALLOW_UNAUTH_IN_DEV=true
RUN_TIMEOUT_MS=120000
# Optional per-mode HTTP/run timeout overrides (ms). When unset, RUN_TIMEOUT_MS applies.
# RUN_TIMEOUT_MS_PIPELINE=180000
# RUN_TIMEOUT_MS_PARALLEL=
# RUN_TIMEOUT_MS_DEBATE=
# RUN_TIMEOUT_MS_VOTE=
# RUN_TIMEOUT_MS_ROUNDTABLE=
# RUN_TIMEOUT_MS_COMPANY=
MAX_RUN_CONCURRENCY=3
RUN_RATE_LIMIT_PER_MINUTE=30
RUN_QUEUE_SIZE=20
RUN_MAX_RETRIES=0
USD_PER_1K_TOKENS=0.002

# Embedding retriever via local Ollama (qwen3:14b available on your machine)
ENABLE_EMBEDDING_RETRIEVER=false
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_EMBED_MODEL=qwen3:14b
KB_CHUNK_SIZE=500
KB_CHUNK_OVERLAP=80

# Intelligence pipeline action provider — mock (default) or local (NanoClaw-style sandbox + mock fallback for non-local actions)
# INTELLIGENCE_PROVIDER=mock
# INTELLIGENCE_LOCAL_ROOT=   # optional; default <RECORDS_ROOT>/nanoclaw-workspace
# INTELLIGENCE_SHELL_ALLOWLIST=   # e.g. echo,node — empty disables local_shell
# INTELLIGENCE_HTTP_ALLOWLIST=127.0.0.1,localhost,example.com

KIMI_API_KEY=replace-with-kimi-api-key
KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_MODEL=kimi-k2p5

# Seedance 2.0 (AIGC video) via AI/ML API proxy — optional; server exposes POST/GET /api/capabilities/seedance/video
# AIMLAPI_KEY=
# SEEDANCE_API_KEY=
# AIMLAPI_BASE_URL=https://api.aimlapi.com
