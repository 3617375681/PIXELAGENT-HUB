# ============================================================
# PixelAgent Hub — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.

# ---------- LLM Provider ----------
# Which LLM provider to use: openai | anthropic | deepseek | kimi | ollama | custom-openai-compat
# If unset, auto-detects from available API keys.
LLM_PROVIDER=kimi

# Generic override keys (work for all providers)
LLM_API_KEY=your-api-key-here
LLM_BASE_URL=
LLM_MODEL=

# Provider-specific keys (takes precedence over generic)
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
ANTHROPIC_MODEL=claude-sonnet-4-6

DEEPSEEK_API_KEY=sk-...
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

KIMI_API_KEY=sk-...
KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_MODEL=kimi-k2p5

# Ollama (no API key needed)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:14b

# ---------- Search Provider ----------
# brave | tavily | (unset = mock)
SEARCH_PROVIDER=
BRAVE_SEARCH_API_KEY=
TAVILY_API_KEY=

# ---------- Messaging Provider ----------
# slack | discord | (unset = mock)
MESSAGE_PROVIDER=
SLACK_WEBHOOK_URL=
DISCORD_WEBHOOK_URL=

# ---------- Feishu / Lark ----------
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_BASE_URL=https://open.feishu.cn/open-apis
FEISHU_BITABLE_APP_TOKEN=
FEISHU_BITABLE_TABLE_ID=

# ---------- Embedding (Ollama) ----------
ENABLE_EMBEDDING_RETRIEVER=false
OLLAMA_EMBED_MODEL=qwen3:14b
KB_CHUNK_SIZE=500
KB_CHUNK_OVERLAP=80

# ---------- Web Server ----------
NODE_ENV=development
RECORDS_API_PORT=3100
RECORDS_API_KEY=change-me-in-production-at-least-16-chars
ALLOW_UNAUTH_IN_DEV=true
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ---------- Run Limits ----------
RUN_TIMEOUT_MS=120000
MAX_RUN_CONCURRENCY=3
RUN_RATE_LIMIT_PER_MINUTE=30
RUN_QUEUE_SIZE=20
RUN_MAX_RETRIES=0

# ---------- Per-mode timeout overrides (ms) ----------
# RUN_TIMEOUT_MS_PIPELINE=60000
# RUN_TIMEOUT_MS_PARALLEL=60000
# RUN_TIMEOUT_MS_DEBATE=180000
# RUN_TIMEOUT_MS_VOTE=60000
# RUN_TIMEOUT_MS_ROUNDTABLE=180000
# RUN_TIMEOUT_MS_COMPANY=300000

# ---------- Cost estimation ----------
USD_PER_1K_TOKENS=0.002

# ---------- Intelligence Pipeline ----------
INTELLIGENCE_PROVIDER=mock
RECORDS_ROOT_OVERRIDE=
INTELLIGENCE_LOCAL_MAX_READ=262144
INTELLIGENCE_LOCAL_MAX_WRITE=1048576
INTELLIGENCE_SHELL_ALLOWLIST=
INTELLIGENCE_HTTP_ALLOWLIST=127.0.0.1,localhost,example.com

# ---------- Seedance AIGC Video ----------
SEEDANCE_API_KEY=
SEEDANCE_BASE_URL=
