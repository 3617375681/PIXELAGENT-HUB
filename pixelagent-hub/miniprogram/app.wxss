/* PixelAgent Hub — Global Styles (Pixel Retro Theme) */

page {
  background-color: #0a0a14;
  color: #e0e0e0;
  font-family: 'Courier New', Courier, monospace;
  font-size: 14px;
  line-height: 1.6;
}

/* ===== Utility Classes ===== */
.pixel-font {
  font-family: 'Courier New', Courier, monospace;
  letter-spacing: 1px;
}

.pixel-card {
  background: #111122;
  border: 1px solid rgba(255, 255, 255, 0.1);
  padding: 12px;
  border-radius: 0;
}

.pixel-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 8px 16px;
  border: 1px solid rgba(255, 255, 255, 0.2);
  background: #1a1a2e;
  color: #e0e0e0;
  font-family: 'Courier New', Courier, monospace;
  font-size: 12px;
  letter-spacing: 1px;
}

.pixel-btn:active {
  background: #2a2a4e;
  border-color: #00ff88;
}

.pixel-btn-primary {
  background: #0a3a1a;
  border-color: #00ff8844;
  color: #00ff88;
}

.pixel-btn-primary:active {
  background: #0a5a2a;
}

.pixel-btn-sm {
  padding: 4px 10px;
  font-size: 10px;
}

.pixel-input {
  background: #0a0a18;
  border: 1px solid rgba(255, 255, 255, 0.15);
  color: #e0e0e0;
  padding: 8px 12px;
  font-family: 'Courier New', Courier, monospace;
  font-size: 13px;
}

.pixel-input:focus {
  border-color: #00ff88;
}

/* ===== Scrollbar ===== */
::-webkit-scrollbar {
  width: 4px;
}

::-webkit-scrollbar-track {
  background: #0a0a14;
}

::-webkit-scrollbar-thumb {
  background: #333;
}

/* ===== Animation ===== */
@keyframes blink {
  0%, 100% { opacity: 1; }
  50% { opacity: 0; }
}

@keyframes pulse-border {
  0%, 100% { border-color: rgba(0, 255, 136, 0.2); }
  50% { border-color: rgba(0, 255, 136, 0.8); }
}

@keyframes slide-up {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.animate-blink {
  animation: blink 1s step-end infinite;
}

.animate-slide-up {
  animation: slide-up 0.3s ease-out;
}

/* ===== Status Colors ===== */
.text-green { color: #00ff88; }
.text-amber { color: #f59e0b; }
.text-red { color: #ef4444; }
.text-blue { color: #00d4ff; }
.text-muted { color: rgba(255, 255, 255, 0.35); }

.bg-green-subtle { background: rgba(0, 255, 136, 0.1); }
.bg-amber-subtle { background: rgba(245, 158, 11, 0.1); }
.bg-red-subtle { background: rgba(239, 68, 68, 0.1); }
