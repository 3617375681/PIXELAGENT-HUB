/* Message Card Component — Pixel Theme */

.msg-card {
  padding: 12px;
  margin-bottom: 12px;
  border-left: 3px solid #333;
  background: rgba(255, 255, 255, 0.03);
}

.msg-user {
  border-left-color: #00ff88;
  background: rgba(0, 255, 136, 0.04);
}

.msg-assistant {
  border-left-color: #00d4ff;
  background: rgba(0, 212, 255, 0.04);
}

.msg-header {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 6px;
  flex-wrap: wrap;
}

.msg-role {
  font-size: 10px;
  font-weight: bold;
  letter-spacing: 1px;
  font-family: 'Courier New', Courier, monospace;
}

.msg-type-badge {
  font-size: 8px;
  padding: 1px 6px;
  font-family: 'Courier New', Courier, monospace;
  letter-spacing: 1px;
}

.badge-info {
  border: 1px solid rgba(0, 212, 255, 0.4);
  color: #00d4ff;
}

.badge-error {
  border: 1px solid rgba(239, 68, 68, 0.4);
  color: #ef4444;
}

.badge-streaming {
  border: 1px solid rgba(245, 158, 11, 0.6);
  color: #f59e0b;
  animation: pulse-border 1.5s infinite;
}

.msg-time {
  font-size: 9px;
  margin-left: auto;
}

.msg-retry {
  font-size: 9px;
  padding: 2px 6px;
  border: 1px solid rgba(239, 68, 68, 0.3);
  border-radius: 0;
}

.msg-retry:active {
  background: rgba(239, 68, 68, 0.15);
}

.msg-body {
  line-height: 1.7;
}

.msg-content {
  font-size: 13px;
  white-space: pre-wrap;
  word-break: break-all;
}

.msg-streaming {
  display: inline;
}

.cursor-blink {
  animation: blink 0.8s step-end infinite;
  color: #f59e0b;
}

.msg-attachments {
  margin-top: 8px;
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
}

.msg-img {
  width: 150px;
  border: 1px solid rgba(255, 255, 255, 0.1);
}

.msg-file {
  font-size: 10px;
  padding: 4px 8px;
  border: 1px solid rgba(255, 255, 255, 0.1);
}
