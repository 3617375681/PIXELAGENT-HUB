/* PixelAgent Hub — Chat Page Styles */

.chat-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #0a0a14;
}

/* ===== Header ===== */
.chat-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 32rpx;
  border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  background: #0a0a14;
  flex-shrink: 0;
}

.chat-title {
  font-size: 26rpx;
  letter-spacing: 2px;
}

.header-actions {
  display: flex;
  gap: 8rpx;
  font-size: 20rpx;
}

/* ===== Message List ===== */
.msg-list {
  flex: 1;
  padding: 16rpx 24rpx;
  overflow-y: auto;
}

.msg-wrapper {
  margin-bottom: 4rpx;
}

/* Empty State */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 48rpx 48rpx;
  gap: 16rpx;
}

.empty-icon {
  font-size: 64rpx;
  opacity: 0.3;
}

.empty-title {
  font-size: 32rpx;
}

.empty-desc {
  font-size: 24rpx;
  text-align: center;
  line-height: 1.6;
}

.empty-hints {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  justify-content: center;
  margin-top: 20rpx;
}

.hint-chip {
  padding: 8rpx 20rpx;
  border: 1px solid rgba(255, 255, 255, 0.08);
  font-size: 20rpx;
}

.hint-chip:active {
  border-color: rgba(0, 255, 136, 0.3);
  background: rgba(0, 255, 136, 0.05);
}

/* System Message */
.system-msg {
  margin: 16rpx 0;
  padding: 16rpx;
  background: rgba(0, 212, 255, 0.04);
  border: 1px solid rgba(0, 212, 255, 0.1);
}

.system-label {
  font-size: 18rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
  display: block;
}

.system-body {
  white-space: pre-wrap;
  word-break: break-all;
}

.system-text {
  font-size: 22rpx;
  line-height: 1.6;
}

/* ===== Attachments Bar ===== */
.attachments-bar {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  padding: 12rpx 24rpx;
  background: rgba(255, 255, 255, 0.02);
  border-top: 1px solid rgba(255, 255, 255, 0.05);
}

.file-chip {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 6rpx 16rpx;
  background: rgba(255, 255, 255, 0.06);
  border: 1px solid rgba(255, 255, 255, 0.1);
}

.file-icon {
  font-size: 22rpx;
}

.file-name {
  font-size: 20rpx;
  max-width: 200rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.file-remove {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.3);
  padding: 4rpx;
}

/* ===== Slash Menu ===== */
.slash-menu {
  position: absolute;
  bottom: 120rpx;
  left: 24rpx;
  right: 24rpx;
  background: #111122;
  border: 1px solid rgba(0, 255, 136, 0.15);
  max-height: 400rpx;
  overflow-y: auto;
  z-index: 10;
  box-shadow: 0 -8rpx 24rpx rgba(0, 0, 0, 0.4);
}

.slash-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 24rpx;
  border-bottom: 1px solid rgba(255, 255, 255, 0.03);
}

.slash-item:active {
  background: rgba(0, 255, 136, 0.05);
}

.slash-cmd {
  font-size: 24rpx;
  font-weight: bold;
  min-width: 120rpx;
}

.slash-desc {
  font-size: 22rpx;
  flex: 1;
}

.slash-usage {
  font-size: 18rpx;
}

/* ===== Composer ===== */
.composer {
  display: flex;
  align-items: flex-end;
  gap: 12rpx;
  padding: 16rpx 24rpx 24rpx;
  background: #0a0a14;
  border-top: 1px solid rgba(255, 255, 255, 0.05);
  flex-shrink: 0;
}

.composer-actions {
  display: flex;
  gap: 4rpx;
  padding-bottom: 12rpx;
}

.composer-btn {
  font-size: 36rpx;
  padding: 8rpx;
  opacity: 0.6;
}

.composer-btn:active {
  opacity: 1;
}

.input-wrapper {
  flex: 1;
}

.composer-input {
  width: 100%;
  height: 72rpx;
  padding: 0 20rpx;
  font-size: 26rpx;
  box-sizing: border-box;
  border: 1px solid rgba(255, 255, 255, 0.1);
  background: #111122;
  color: #e0e0e0;
}

.composer-send {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  padding: 0;
  flex-shrink: 0;
}

.composer-stop {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  padding: 0;
  flex-shrink: 0;
  background: rgba(239, 68, 68, 0.15);
  border-color: rgba(239, 68, 68, 0.3);
  color: #ef4444;
}

/* ===== Debug Bar ===== */
.debug-bar {
  padding: 8rpx 24rpx;
  background: rgba(0, 0, 0, 0.3);
  border-top: 1px solid rgba(255, 255, 255, 0.05);
  font-size: 18rpx;
  text-align: center;
  flex-shrink: 0;
}
